generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model action_fields {
  id                     Int                      @id @default(autoincrement()) @db.UnsignedInt
  action_id              Int                      @db.UnsignedInt
  type                   String
  name                   String
  values                 String?                  @db.Text
  required               Boolean                  @default(false)
  a2af                   Boolean                  @default(false)
  created_at             DateTime?                @db.Timestamp(0)
  updated_at             DateTime?                @db.Timestamp(0)
  deleted_at             DateTime?                @db.Timestamp(0)
  actions                actions                  @relation(fields: [action_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_action_fields_actions")
  activity_action_fields activity_action_fields[]

  @@index([action_id], map: "fk_action_fields_actions")
}

model action_service_states {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  service_id Int       @db.UnsignedInt
  action_id  Int       @db.UnsignedInt
  state_id   Int?      @db.UnsignedInt
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  actions    actions   @relation(fields: [action_id], references: [id], onDelete: Cascade, map: "fk_action_service_states_actions")
  services   services  @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_action_service_states_services")
  states     states?   @relation(fields: [state_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_action_service_states_states")

  @@index([action_id], map: "fk_action_service_states_actions")
  @@index([service_id], map: "fk_action_service_states_services")
  @@index([state_id], map: "fk_action_service_states_states")
}

model actions {
  id                      Int                     @id @default(autoincrement()) @db.UnsignedInt
  name                    String
  state_id                Int?
  created_at              DateTime?               @db.Timestamp(0)
  updated_at              DateTime?               @db.Timestamp(0)
  deleted_at              DateTime?               @db.Timestamp(0)
  required_dictum         Boolean?
  required_employment     Boolean?
  required_documents      Boolean?
  required_diagnostic     Boolean?
  required_fulldiagnostic Boolean?
  restore_user            Boolean?
  required_fields         Boolean?
  documents               String?
  send_targets            String?
  dictum_dates            String?
  new_service             Int?
  required_list_documents String?
  auto_alert              Int?
  auto_alert_calendar     Int?
  action_fields           action_fields[]
  action_service_states   action_service_states[]
  activity_actions        activity_actions[]
  service_actions         service_actions[]
  state_actions           state_actions[]
}

model activities {
  id                                    Int                                     @id @default(autoincrement()) @db.UnsignedInt
  parent_id                             Int?                                    @db.UnsignedInt
  client_id                             Int                                     @db.UnsignedInt
  affiliate_id                          Int                                     @db.UnsignedInt
  service_id                            Int                                     @db.UnsignedInt
  employment_id                         Int?                                    @db.UnsignedInt
  information_source                    Int?
  auth_number                           String?
  state_id                              Int                                     @db.UnsignedInt
  user_id                               Int                                     @db.UnsignedInt
  finished_at                           DateTime?                               @db.Timestamp(0)
  created_at                            DateTime?                               @db.DateTime(0)
  updated_at                            DateTime?                               @db.DateTime(0)
  deleted_at                            DateTime?                               @db.Timestamp(0)
  invoiced                              Boolean?
  invoice_id                            Int?                                    @db.UnsignedInt
  audited_sicat                         String?                                 @db.VarChar(10)
  activities                            activities?                             @relation("activitiesToactivities", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activities_activities")
  other_activities                      activities[]                            @relation("activitiesToactivities")
  affiliates                            affiliates                              @relation(fields: [affiliate_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activities_affiliates")
  clients                               clients                                 @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activities_clients")
  employments                           employments?                            @relation(fields: [employment_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activities_employments")
  services                              services                                @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activities_services")
  states                                states                                  @relation(fields: [state_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activities_states")
  users                                 users                                   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activities_users")
  activity_actions                      activity_actions[]
  activity_documents                    activity_documents[]
  activity_service_fields               activity_service_fields[]
  correspondence_items                  correspondence_items[]
  dicta                                 dicta[]
  docinvoice_activities                 docinvoice_activities[]
  glosas                                glosas[]
  life_debtor_insurance_without_reports life_debtor_insurance_without_reports[]
  life_debtor_insurances                life_debtor_insurances[]
  life_insurance_without_reports        life_insurance_without_reports[]
  life_insurances                       life_insurances[]
  pcls                                  pcls[]
  personal_accident_without_reports     personal_accident_without_reports[]
  personal_accidents                    personal_accidents[]
  personal_injuries                     personal_injuries[]
  personal_injury_without_reports       personal_injury_without_reports[]
  quotes                                quotes[]
  rehabilitations                       rehabilitations[]
  wheaters                              wheaters[]

  @@index([parent_id], map: "fk_activities_activities")
  @@index([affiliate_id], map: "fk_activities_affiliates")
  @@index([client_id], map: "fk_activities_clients")
  @@index([employment_id], map: "fk_activities_employments")
  @@index([service_id], map: "fk_activities_services")
  @@index([state_id], map: "fk_activities_states")
  @@index([user_id], map: "fk_activities_users")
}

model activity_action_deletes {
  id                 Int              @id @default(autoincrement()) @db.UnsignedInt
  activity_action_id Int              @db.UnsignedInt
  activity_id        Int?
  action_id          Int?
  author_id          Int              @db.UnsignedInt
  deleted_date       DateTime?        @db.DateTime(0)
  created_at         DateTime?        @db.Timestamp(0)
  updated_at         DateTime?        @db.Timestamp(0)
  activity_actions   activity_actions @relation(fields: [activity_action_id], references: [id], onUpdate: Restrict, map: "fk_activity_action_deletes_activity_actions")

  @@index([activity_action_id], map: "fk_activity_action_deletes_activity_actions")
}

model activity_action_documents {
  id                   Int                    @id @default(autoincrement()) @db.UnsignedInt
  activity_action_id   Int                    @db.UnsignedInt
  name                 String
  path                 String
  created_at           DateTime?              @db.Timestamp(0)
  updated_at           DateTime?              @db.Timestamp(0)
  deleted_at           DateTime?              @db.Timestamp(0)
  activity_actions     activity_actions       @relation(fields: [activity_action_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_action_documents_activity_actions")
  correspondence_items correspondence_items[]

  @@index([activity_action_id], map: "fk_activity_action_documents_activity_actions")
}

model activity_action_fields {
  id                 Int              @id @default(autoincrement()) @db.UnsignedInt
  activity_action_id Int              @db.UnsignedInt
  action_field_id    Int              @db.UnsignedInt
  value              String?          @db.Text
  created_at         DateTime?        @db.Timestamp(0)
  updated_at         DateTime?        @db.Timestamp(0)
  action_fields      action_fields    @relation(fields: [action_field_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_action_fields_action_fields")
  activity_actions   activity_actions @relation(fields: [activity_action_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_action_fields_activity_actions")

  @@index([action_field_id], map: "fk_activity_action_fields_action_fields")
  @@index([activity_action_id], map: "fk_activity_action_fields_activity_actions")
}

model activity_actions {
  id                                           Int                         @id @default(autoincrement()) @db.UnsignedInt
  activity_id                                  Int                         @db.UnsignedInt
  action_id                                    Int                         @db.UnsignedInt
  old_state_id                                 Int                         @db.UnsignedInt
  new_state_id                                 Int                         @db.UnsignedInt
  alert_date                                   DateTime?                   @db.Date
  description                                  String?                     @db.Text
  old_user_id                                  Int?                        @db.UnsignedInt
  new_user_id                                  Int?                        @db.UnsignedInt
  author_id                                    Int                         @db.UnsignedInt
  created_at                                   DateTime?                   @db.DateTime(0)
  updated_at                                   DateTime?                   @db.DateTime(0)
  deleted_at                                   DateTime?                   @db.Timestamp(0)
  old_id                                       Int?
  activity_action_deletes                      activity_action_deletes[]
  activity_action_documents                    activity_action_documents[]
  activity_action_fields                       activity_action_fields[]
  actions                                      actions                     @relation(fields: [action_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_actions_actions")
  activities                                   activities                  @relation(fields: [activity_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_actions_activities")
  states_activity_actions_old_state_idTostates states                      @relation("activity_actions_old_state_idTostates", fields: [old_state_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_actions_states")
  states_activity_actions_new_state_idTostates states                      @relation("activity_actions_new_state_idTostates", fields: [new_state_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_actions_states2")
  users_activity_actions_old_user_idTousers    users?                      @relation("activity_actions_old_user_idTousers", fields: [old_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_actions_users")
  users_activity_actions_new_user_idTousers    users?                      @relation("activity_actions_new_user_idTousers", fields: [new_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_actions_users2")
  correspondence_items                         correspondence_items[]

  @@index([action_id], map: "fk_activity_actions_actions")
  @@index([activity_id], map: "fk_activity_actions_activities")
  @@index([old_state_id], map: "fk_activity_actions_states")
  @@index([new_state_id], map: "fk_activity_actions_states2")
  @@index([old_user_id], map: "fk_activity_actions_users")
  @@index([new_user_id], map: "fk_activity_actions_users2")
}

model activity_documents {
  id                  Int                @id @default(autoincrement()) @db.UnsignedInt
  document_id         Int?               @db.UnsignedInt
  activity_id         Int                @db.UnsignedInt
  path                String?
  uploaded_at         DateTime?          @db.Timestamp(0)
  summary             String?            @db.Text
  include_in_dictamen Boolean            @default(false)
  include_in_others   Boolean            @default(false)
  created_at          DateTime?          @db.Timestamp(0)
  updated_at          DateTime?          @db.Timestamp(0)
  deleted_at          DateTime?          @db.Timestamp(0)
  physical            Boolean            @default(false)
  activities          activities         @relation(fields: [activity_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_documents_activities")
  service_documents   service_documents? @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_documents_service_documents")

  @@index([activity_id], map: "fk_activity_documents_activities")
  @@index([document_id], map: "fk_activity_documents_service_documents")
}

model activity_service_fields {
  id               Int            @id @default(autoincrement()) @db.UnsignedInt
  activity_id      Int            @db.UnsignedInt
  service_field_id Int            @db.UnsignedInt
  value            String?        @db.Text
  created_at       DateTime?      @db.Timestamp(0)
  updated_at       DateTime?      @db.Timestamp(0)
  activities       activities     @relation(fields: [activity_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_service_fields_activities")
  service_fields   service_fields @relation(fields: [service_field_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_activity_service_fields_service_fields")

  @@index([activity_id], map: "fk_activity_service_fields_activities")
  @@index([service_field_id], map: "fk_activity_service_fields_service_fields")
}

model affiliate_files {
  id           Int       @id @default(autoincrement()) @db.UnsignedInt
  affiliate_id Int
  category     String
  path         String
  comment      String
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  deleted_at   DateTime? @db.Timestamp(0)
}

