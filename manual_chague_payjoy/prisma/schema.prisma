model areas {
  id          Int           @id @default(autoincrement()) @db.UnsignedInt
  name        String
  created_at  DateTime?     @db.Timestamp(0)
  updated_at  DateTime?     @db.Timestamp(0)
  state_areas state_areas[]
  users       users[]
}

model branches {
  id           Int           @id @default(autoincrement()) @db.UnsignedInt
  employer_id  Int           @db.UnsignedInt
  name         String
  department   Int
  municipality Int
  address      String
  contact      String
  phone        String
  cellphone    String
  email        String
  created_at   DateTime?     @db.Timestamp(0)
  updated_at   DateTime?     @db.Timestamp(0)
  deleted_at   DateTime?     @db.Timestamp(0)
  employers    employers     @relation(fields: [employer_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_branches_employers")
  employments  employments[]

  @@index([employer_id], map: "fk_branches_employers")
}

model busy_schedules {
  id                   Int       @id @default(autoincrement()) @db.UnsignedInt
  user_id              Int       @db.UnsignedInt
  type                 String    @db.VarChar(50)
  name_affiliate       String?   @db.VarChar(255)
  doc_type_affiliate   String?   @db.VarChar(255)
  doc_number_affiliate String?   @db.VarChar(255)
  email_affiliate      String?   @db.VarChar(255)
  date_schedule        DateTime  @db.Date
  time_init            DateTime  @db.Time(0)
  time_end             DateTime  @db.Time(0)
  id_renapp            Int?
  client_id            Int?
  observation          String?   @db.Text
  message_deleted      String?   @db.Text
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)
  deleted_at           DateTime? @db.Timestamp(0)
  users                users     @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "busy_schedules_users_id_fk")

  @@index([user_id], map: "busy_schedules_users_id_fk")
}

model cache {
  key        String @unique(map: "cache_key_unique")
  value      String @db.Text
  expiration Int
}

model calendar_month {
  start_day DateTime @unique(map: "calendar_month_start_day_uindex") @db.Date
  end_day   DateTime @unique(map: "calendar_month_end_day_uindex") @db.Date
}

model charges {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  id_charge  String    @db.VarChar(255)
  file       String    @db.Text
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  retry_url  String    @db.Text
  total      Int?      @db.UnsignedInt
  name       String?   @db.VarChar(255)
}

model ciius {
  id           Int       @id @default(autoincrement()) @db.UnsignedInt
  cod          String
  descriptions String?   @db.Text
  industrial   String?   @db.Text
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  deleted_at   DateTime? @db.Timestamp(0)
}

model client_services {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  client_id  Int       @db.UnsignedInt
  service_id Int       @db.UnsignedInt
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  services   services  @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_client_services_services")

  @@index([service_id], map: "fk_client_services_services")
}

model clients {
  id                        Int                   @id @default(autoincrement()) @db.UnsignedInt
  path                      String
  name                      String
  color                     String                @default("black")
  logo                      String?
  client_type               Int
  client_default            Int?
  created_at                DateTime?             @db.Timestamp(0)
  updated_at                DateTime?             @db.Timestamp(0)
  deleted_at                DateTime?             @db.Timestamp(0)
  nickname                  String?
  footer                    String?               @db.Text
  email                     String?
  address                   String?
  phone                     String?
  productivity_profesionals String?               @db.Text
  productivity_assistants   String?               @db.Text
  activities                activities[]
  affiliates                affiliates[]
  correspondences           correspondences[]
  information_sources       information_sources[]
  service_billings          service_billings[]
  service_projections       service_projections[]
}

model correspondence_items {
  id                          Int                        @id @default(autoincrement()) @db.UnsignedInt
  state                       Int                        @default(1)
  correspondence_id           Int                        @db.UnsignedInt
  order                       Int?
  entity_type                 String
  name                        String
  address                     String                     @db.VarChar(255)
  phone                       String
  department                  Int
  municipality                Int
  guide                       String?
  activity_id                 Int?                       @db.UnsignedInt
  activity_action_id          Int?                       @db.UnsignedInt
  activity_action_document_id Int?                       @db.UnsignedInt
  notified_at                 DateTime?                  @db.Date
  main                        Boolean                    @default(false)
  path                        String?
  created_at                  DateTime?                  @db.Timestamp(0)
  updated_at                  DateTime?                  @db.Timestamp(0)
  deleted_at                  DateTime?                  @db.Timestamp(0)
  cause_of_return             String?                    @db.Text
  internal                    String?                    @db.VarChar(250)
  activities                  activities?                @relation(fields: [activity_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_correspondence_items_activities")
  activity_action_documents   activity_action_documents? @relation(fields: [activity_action_document_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_correspondence_items_activity_action_documents")
  activity_actions            activity_actions?          @relation(fields: [activity_action_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_correspondence_items_activity_actions")
  correspondences             correspondences            @relation(fields: [correspondence_id], references: [id], onUpdate: Restrict, map: "fk_correspondence_items_correspondences")

  @@index([activity_id], map: "fk_correspondence_items_activities")
  @@index([activity_action_document_id], map: "fk_correspondence_items_activity_action_documents")
  @@index([activity_action_id], map: "fk_correspondence_items_activity_actions")
  @@index([correspondence_id], map: "fk_correspondence_items_correspondences")
}

model correspondences {
  id                   Int                    @id @default(autoincrement()) @db.UnsignedInt
  client_id            Int                    @db.UnsignedInt
  consecutive          Int
  counter              Int                    @default(1)
  send_at              DateTime?              @db.Date
  order_type           Int                    @default(1)
  closed               Boolean                @default(false)
  created_at           DateTime?              @db.Timestamp(0)
  updated_at           DateTime?              @db.Timestamp(0)
  correspondence_items correspondence_items[]
  clients              clients                @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_correspondences_clients")

  @@index([client_id], map: "fk_correspondences_clients")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
