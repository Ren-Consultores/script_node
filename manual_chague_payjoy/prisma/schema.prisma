  birthday                 DateTime?     @db.Date
  gender                   String?
  address                  String?       @db.VarChar(255)
  phone                    String?
  cellphone                String?
  email                    String?
  department               Int?
  municipality             Int?
  civil_status             Int?
  school_level             Int?
  ibc                      Float?
  affiliation_type         Int
  eps                      Int
  arl                      Int
  afp                      Int
  regimen                  String?       @db.VarChar(100)
  clinical_history_summary String?       @db.Text
  created_at               DateTime?     @db.DateTime(0)
  updated_at               DateTime?     @db.DateTime(0)
  deleted_at               DateTime?     @db.Timestamp(0)
  regional                 Int?
